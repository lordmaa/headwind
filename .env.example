# ── Required ────────────────────────────────────────────────────
# Generate a random string: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Login credentials for the web UI
APP_USERNAME=admin
APP_PASSWORD=changeme

# ── Strava (optional — skip if just importing .fit / .gpx files) ─
# Create a Strava API app at https://www.strava.com/settings/api
# Set the callback domain to your APP_URL host.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
APP_URL=http://localhost:5001
STRAVA_WEBHOOK_TOKEN=changeme

# ── AI coaching (optional) ───────────────────────────────────────
# Paste an OpenAI or Anthropic key to enable AI ride analysis.
# Leave blank to disable — everything else still works.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Notes ────────────────────────────────────────────────────────
# The app starts with two placeholder riders ("Rob" and "Smithy").
# Rename them under Riders in the UI, or add your own.
# MQTT and Garmin credentials are configured inside the app (Settings page).
